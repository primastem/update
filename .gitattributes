# Normalize all text files to LF in the repo (Git will check out as-is
# on Linux/macOS, and as CRLF on Windows if core.autocrlf=true is set
# globally). This prevents the entire repo from showing up as "modified"
# after a Windows checkout.
* text=auto eol=lf

# Explicit text types — be safe even if autodetection misses
*.html       text eol=lf
*.css        text eol=lf
*.js         text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.py         text eol=lf
*.sh         text eol=lf
*.txt        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# Binary assets — never touch line endings, never try to diff as text
*.bin        binary
*.mp3        binary
*.wav        binary
*.ogg        binary
*.zip        binary
*.gz         binary
*.tar        binary
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        binary
*.pdf        binary
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
